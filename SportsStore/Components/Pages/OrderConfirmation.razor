@page "/order-confirmation/{OrderId:int}"
@inject OrderService OrderService

<PageTitle>Order Confirmation - SportsStore</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card border-success">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="card-title text-success">Thank You!</h2>
                    <p class="card-text fs-5">Your order has been placed successfully.</p>
                    <p class="card-text">Order Number: <strong>#@OrderId</strong></p>

                    @if (order != null)
                    {
                        <div class="mt-4 text-start">
                            <h5>Order Details:</h5>
                            <ul class="list-unstyled">
                                <li><strong>Status:</strong> @order.OrderStatus</li>
                                <li><strong>Total:</strong> @order.TotalAmount.ToString("C")</li>
                                <li><strong>Items:</strong> @order.ItemCount</li>
                            </ul>
                        </div>
                    }

                    <div class="mt-4">
                        <a href="/" class="btn btn-primary me-2">Continue Shopping</a>
                        <a href="/orders" class="btn btn-outline-primary">View My Orders</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int OrderId { get; set; }

    private OrderResponseDto? order;

    protected override async Task OnInitializedAsync()
    {
        order = await OrderService.GetOrderAsync(OrderId);
    }
}
