@page "/order-details/{OrderId:int}"
@inject OrderService OrderService

<PageTitle>Order Details - SportsStore</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Order #@OrderId</h2>

    @if (IsLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (order == null)
    {
        <div class="alert alert-danger">Order not found.</div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Order Status</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">Status: <span class="badge @GetStatusClass(order.OrderStatus)">@order.OrderStatus</span></h6>
                                <small class="text-muted">Placed on @order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                            </div>
                            <div class="text-end">
                                <strong>Total: @order.TotalAmount.ToString("C")</strong>
                            </div>
                        </div>

                        @if (status != null)
                        {
                            <hr />
                            <h6>Processing Status:</h6>
                            <div class="row mt-3">
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <div class="mb-2">
                                            <i class="fas fa-box @(status.InventoryStatus != null ? "text-success" : "text-muted")" style="font-size: 1.5rem;"></i>
                                        </div>
                                        <small>Inventory</small>
                                        <div><span class="badge @(GetStatusBadgeClass(status.InventoryStatus))">@(status.InventoryStatus ?? "Pending")</span></div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <div class="mb-2">
                                            <i class="fas fa-credit-card @(status.PaymentStatus != null ? "text-success" : "text-muted")" style="font-size: 1.5rem;"></i>
                                        </div>
                                        <small>Payment</small>
                                        <div><span class="badge @(GetStatusBadgeClass(status.PaymentStatus))">@(status.PaymentStatus ?? "Pending")</span></div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <div class="mb-2">
                                            <i class="fas fa-truck @(status.ShippingStatus != null ? "text-success" : "text-muted")" style="font-size: 1.5rem;"></i>
                                        </div>
                                        <small>Shipping</small>
                                        <div><span class="badge @(GetStatusBadgeClass(status.ShippingStatus))">@(status.ShippingStatus ?? "Pending")</span></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Items</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            @foreach (var item in orderItems)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-0">@item.ProductName</h6>
                                        <small class="text-muted">Qty: @item.Quantity x @item.UnitPrice.ToString("C")</small>
                                    </div>
                                    <span class="fw-bold">@((item.Quantity * item.UnitPrice).ToString("C"))</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Shipping Address</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong>@order.Name</strong></p>
                        <p class="mb-1">@order.Line1</p>
                        @if (!string.IsNullOrEmpty(order.Line2))
                        {
                            <p class="mb-1">@order.Line2</p>
                        }
                        @if (!string.IsNullOrEmpty(order.Line3))
                        {
                            <p class="mb-1">@order.Line3</p>
                        }
                        <p class="mb-1">@order.City, @order.State @order.Zip</p>
                        <p class="mb-0">@order.Country</p>
                    </div>
                </div>

                <div class="card mt-4">
                    <div class="card-header">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal (@order.ItemCount items)</span>
                            <span>@order.TotalAmount.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping</span>
                            <span>Free</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Total</span>
                            <span>@order.TotalAmount.ToString("C")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="mt-4">
        <a href="/orders" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left"></i> Back to Orders
        </a>
    </div>
</div>

@code {
    [Parameter]
    public int OrderId { get; set; }

    private OrderResponseDto? order;
    private OrderStatusResponse? status;
    private List<OrderItemDto> orderItems = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderDetails();
    }

    private async Task LoadOrderDetails()
    {
        IsLoading = true;
        try
        {
            order = await OrderService.GetOrderAsync(OrderId);
            status = await OrderService.GetOrderStatusAsync(OrderId);

            if (order != null)
            {
                // In a real app, these would come from the API
                orderItems = new List<OrderItemDto>();
            }
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Completed" => "bg-success",
            "Failed" => "bg-danger",
            "Cancelled" => "bg-secondary",
            _ => "bg-primary"
        };
    }

    private string GetStatusBadgeClass(string? status)
    {
        return status?.ToLower() switch
        {
            "confirmed" or "approved" or "created" or "completed" => "bg-success",
            "failed" or "rejected" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
